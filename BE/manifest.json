{
  "manifest_version": 3,
  "name": "B站虚拟关注 - RSS订阅",
  "version": "1.0.0",
  "description": "突破5000关注上限，将UP主转为RSS订阅，可导出OPML或内置阅读",
  "permissions": [
    "storage",
    "alarms",
    "downloads"
  ],
  "host_permissions": [
    "*://space.bilibili.com/*",
    "https://rsshub.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://space.bilibili.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "我的虚拟关注"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}